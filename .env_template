# CodeEval environment template
# Copy to `.env` and fill in keys for the providers you use.
# Do NOT commit `.env` with real secrets.

# ==========================================
# API Keys (read by codejudge.core.llm_client)
# ==========================================

# OpenAI (provider=openai / gpt)
OPENAI_API_KEY=sk-your-api-key-here

# OpenRouter (provider=openrouter) — recommended for app.py presets
OPENROUTER_API_KEY=sk-or-v1-...

# Google Gemini (provider=gemini)
GOOGLE_API_KEY=

# Alibaba DashScope / Qwen remote API (provider=qwen with qwen-turbo / qwen-plus)
QWEN_API_KEY=

# Hugging Face (local / gated models)
HUGGINGFACE_TOKEN=

# ==========================================
# Notes
# ==========================================
#
# Providers supported by LLMFactory:
#   openrouter | openai | gemini | qwen | ollama | vllm | local
#
# Ollama default: http://localhost:11434/v1
# vLLM default:   http://localhost:8000/v1
#
# Kaggle: prefer Notebook Secrets instead of .env
#   OPENAI_API_KEY, OPENROUTER_API_KEY, GOOGLE_API_KEY, QWEN_API_KEY, HUGGINGFACE_TOKEN
#
# Temperature / cache / offload paths for local models are handled in code
# (hard-coded or auto-detected on Kaggle); they are not read from this file.
#
