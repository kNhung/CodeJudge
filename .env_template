# CodeJudge Environment Configuration Template
# Copy this to `.env` and fill in your API keys and settings

# ==========================================
# API Keys (Required for remote providers)
# ==========================================

# OpenAI API key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-api-key-here

# Google Gemini API key (get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=AIzaSyYour_Api_Key_Here

# Alibaba Qwen API key (get from https://dashscope.aliyun.com/)
QWEN_API_KEY=sk-your-qwen-api-key

# Hugging Face token (optional, for private models)
HUGGINGFACE_TOKEN=hf_your_token_here

# Nếu dùng OpenRouter (Khuyên dùng và đang chạy trong dự án hiện tại)
OPENROUTER_API_KEY=sk-or-v1-...

# ==========================================
# Cache & Model Directories
# ==========================================

# Hugging Face cache directory
# Default: ~/.cache/huggingface (Linux/Mac) or ~/AppData/Local/huggingface (Windows)
# For Kaggle, auto-set to: /kaggle/working/hf_cache
HF_HOME=~/.cache/huggingface

# Transformers cache directory (alternative to HF_HOME)
TRANSFORMERS_CACHE=~/.cache/huggingface

# Local model root directory
# For Kaggle, auto-set to: /kaggle/working/model
MODEL_ROOT=./model

# Offload folder for low-memory systems (optional)
# For Kaggle, auto-set to: /kaggle/working/offload
# OFFLOAD_FOLDER=./offload

# ==========================================
# Model Selection (optional)
# ==========================================

# Default local model to load
DEFAULT_LOCAL_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# Default remote model (when using OpenAI)
DEFAULT_REMOTE_MODEL=gpt-4

# Default Gemini model
DEFAULT_GEMINI_MODEL=gemini-2.5-flash

# Default Qwen model
DEFAULT_QWEN_MODEL=qwen-turbo

# ==========================================
# Behavior Flags
# ==========================================

# Enable model caching (saves API calls)
USE_MODEL_CACHE=true

# Trust remote code from Hugging Face (set to false on Kaggle for security)
TRUST_REMOTE_CODE=false

# Enable debug logging
DEBUG=false

# ==========================================
# Temperature & Generation Settings
# ==========================================

# Temperature for generation (0.0-1.0)
# Lower = more deterministic, Higher = more creative
TEMPERATURE=0.01

# Top-p for nucleus sampling
TOP_P=0.95


# ==========================================
# Kaggle-Specific Settings
# ==========================================

# (Auto-detected) Set to true if running on Kaggle
# No need to set manually; auto-detected via os.path.exists('/kaggle')
# KAGGLE=false

# Kaggle Notebook Kernel Type
# Auto-set by Kaggle, values: "notebook", "kernel", etc.
# KAGGLE_KERNEL_RUN_TYPE=notebook

# ==========================================
# Advanced Options
# ==========================================

# Bitsandbytes 4-bit quantization (for local models)
USE_4BIT_QUANTIZATION=true

# Offload state dict when loading models
OFFLOAD_STATE_DICT=true

# Low CPU memory usage mode
LOW_CPU_MEM_USAGE=true

# ==========================================
# Notes
# ==========================================
#
# 1. For local setup: fill in OPENAI_API_KEY, GOOGLE_API_KEY, QWEN_API_KEY
#
# 2. For Kaggle: 
#    - Use "Secrets" in notebook settings instead of .env
#    - Add secrets: OPENAI_API_KEY, GOOGLE_API_KEY, QWEN_API_KEY
#    - Load via: from kaggle_secrets import UserSecretsClient
#
# 3. Leave commented out (#) for default values
#
# 4. Do NOT commit this file with real keys to git!
#    Add to .gitignore: .env
#
