# CodeJudge Environment Configuration
# Copy file này thành .env và điền API keys

# ============================================================================
# OPTION 1: OpenAI (GPT-4, GPT-3.5-turbo)
# ============================================================================
# Lấy API key từ: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Mô hình OpenAI (mặc định: gpt-4)
# Lựa chọn: gpt-4, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4


# ============================================================================
# OPTION 2: Anthropic (Claude)
# ============================================================================
# Lấy API key từ: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Mô hình Anthropic (mặc định: claude-3-opus-20240229)
# Lựa chọn: claude-3-opus, claude-3-sonnet, claude-3-haiku
ANTHROPIC_MODEL=claude-3-opus-20240229


# ============================================================================
# OPTION 3: Local LLM (Ollama, vLLM, etc.)
# ============================================================================
# URL của local LLM server
LOCAL_LLM_URL=http://localhost:11434

# Mô hình local (mặc định: llama2)
# Lựa chọn: llama2, mistral, neural-chat, v.v.
LOCAL_LLM_MODEL=llama2


# ============================================================================
# CodeJudge Configuration
# ============================================================================

# Mặc định là "openai", có thể là "anthropic" hoặc "local"
CODEJUDGE_DEFAULT_PROVIDER=openai

# Temperature cho LLM (0.0 - 1.0)
# 0.3 = chặt chẽ (tốt cho phân tích code)
# 0.7 = cân bằng
# 0.9+ = sáng tạo
CODEJUDGE_TEMPERATURE=0.3

# Timeout cho LLM calls (seconds)
CODEJUDGE_TIMEOUT=120

# Số lần retry nếu thất bại
CODEJUDGE_MAX_RETRIES=3


# ============================================================================
# Logging
# ============================================================================
CODEJUDGE_LOG_LEVEL=INFO    # DEBUG, INFO, WARNING, ERROR


# ============================================================================
# Hướng Dẫn Cài Đặt
# ============================================================================

# 1. Chọn một LLM provider (chỉ cần một)
#
# Khuyến nghị:
# - OpenAI: Chính xác cao, chi phí vừa phải (~0.01-0.05 USD/submission)
# - Anthropic: An toàn cao, chi phí tương tự
# - Local LLM: Miễn phí nhưng cần GPU tốt, chính xác thấp hơn

# 2. Lấy API key cho provider của bạn
#    OpenAI: https://platform.openai.com/api-keys
#    Anthropic: https://console.anthropic.com/
#    Local LLM: Cài Ollama từ https://ollama.ai

# 3. Điền API key vào file này (bỏ "your-api-key-here")

# 4. Đổi tên file này thành .env
#    mv .env.example .env

# 5. Test kết nối
#    python -c "from codejudge import LLMFactory; c = LLMFactory.create(); print('OK')"
